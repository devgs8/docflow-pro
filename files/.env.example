# ════════════════════════════════════════════════════════
# DOCFLOW PRO v2.0 — CONFIGURAÇÃO AMBIENTAL
# ════════════════════════════════════════════════════════

# Servidor
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Segurança
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT=100

# Armazenamento
MAX_FILE_SIZE=209715200  # 200MB em bytes
CLEANUP_INTERVAL=3600000  # 1 hora em ms

# Redis (para filas — opcional, usa JSON por defeito)
REDIS_URL=redis://localhost:6379

# Autenticação
SESSION_TIMEOUT=86400000  # 24 horas em ms
ENCRYPTION_SALT=docflow-2024-salt

# API
API_VERSION=v2.0
API_DOCS_ENABLED=true

# Logging
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# Privacidade
ENABLE_ENCRYPTION=true
AUTO_DELETE_AFTER_HOURS=1
GDPR_COMPLIANT=true

# Notificações (opcional)
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@docflow.pro
SMTP_PASS=your-password

# Análise (opcional)
ENABLE_ANALYTICS=false
SENTRY_DSN=

# Feature Flags
FEATURE_OCR=false
FEATURE_SMART_REPAIR=true
FEATURE_COMPRESSION=true
FEATURE_BATCH_PROCESSING=false
FEATURE_API_WEBHOOKS=false

# Limites por Plano (conversões/dia)
PLAN_FREE_LIMIT=15
PLAN_PRO_LIMIT=-1
PLAN_ENTERPRISE_LIMIT=-1

# Tamanhos de ficheiro por plano (bytes)
PLAN_FREE_MAX_SIZE=209715200     # 200MB
PLAN_PRO_MAX_SIZE=1073741824     # 1GB
PLAN_ENTERPRISE_MAX_SIZE=0        # Sem limite

# Desenvolvimento
DEBUG=false
MOCK_CONVERSION=false
BYPASS_AUTH=false
